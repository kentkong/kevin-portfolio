# Where download alerts are sent (your inbox)
RESUME_NOTIFY_EMAIL=you@example.com

# Resend — https://resend.com (free tier works for alerts)
RESEND_API_KEY=
RESEND_FROM="Kevin Portfolio <onboarding@resend.dev>"

# Optional: POST JSON alerts to Slack, Zapier, Make, etc.
# RESUME_NOTIFY_WEBHOOK=https://hooks.example.com/...

# Optional: override PDF filename in private/resume/ (local dev)
# RESUME_PDF_FILENAME=kevin-mold-resume.pdf

# Production (Vercel): host PDF in Vercel Blob and paste the private URL here
# RESUME_PDF_URL=https://....vercel-storage.com/kevin-mold-resume.pdf
